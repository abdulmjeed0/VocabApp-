<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.vocabdaily.ui.screens.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_practiceFragment"
            app:destination="@id/practiceFragment"
            app:enterAnim="@anim/slide_in_up"
            app:exitAnim="@anim/fade_out" />
        <action
            android:id="@+id/action_homeFragment_to_addWordFragment"
            app:destination="@id/addWordFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/fade_out" />
        <action
            android:id="@+id/action_homeFragment_to_statsFragment"
            app:destination="@id/statsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/wordListFragment"
        android:name="com.vocabdaily.ui.screens.WordListFragment"
        android:label="Words"
        tools:layout="@layout/fragment_word_list">
        <action
            android:id="@+id/action_wordListFragment_to_addWordFragment"
            app:destination="@id/addWordFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/fade_out">
            <argument
                android:name="wordId"
                android:defaultValue="-1"
                app:argType="long" />
        </action>
        <action
            android:id="@+id/action_wordListFragment_to_wordDetailFragment"
            app:destination="@id/wordDetailFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/fade_out">
            <argument
                android:name="wordId"
                app:argType="long" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/practiceFragment"
        android:name="com.vocabdaily.ui.screens.PracticeFragment"
        android:label="Practice"
        tools:layout="@layout/fragment_practice" />

    <fragment
        android:id="@+id/statsFragment"
        android:name="com.vocabdaily.ui.screens.StatsFragment"
        android:label="Statistics"
        tools:layout="@layout/fragment_stats" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.vocabdaily.ui.screens.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/addWordFragment"
        android:name="com.vocabdaily.ui.screens.AddWordFragment"
        android:label="Add Word"
        tools:layout="@layout/fragment_add_word">
        <argument
            android:name="wordId"
            android:defaultValue="-1"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/wordDetailFragment"
        android:name="com.vocabdaily.ui.screens.WordDetailFragment"
        android:label="Word Detail"
        tools:layout="@layout/fragment_word_detail">
        <argument
            android:name="wordId"
            app:argType="long" />
    </fragment>

</navigation>
